# Claude Monitor daemon (MQTT) — copy to .env and edit.

# Your MQTT broker. Since you run Mosquitto via HA, this is your Pi's address.
# At the office, point this at your local broker (e.g. tcp://localhost:1883).
MQTT_BROKER=tcp://homeassistant.local:1883

# MQTT credentials (create a user in the Mosquitto add-on, or your HA login).
MQTT_USER=
MQTT_PASS=

# How often to check usage (seconds). 60 = ~$0.02/day in tiny API calls.
POLL_INTERVAL=60

# --- usually leave these defaults ---
# MQTT_CLIENT_ID=claude-monitor-daemon
# MQTT_BASE_TOPIC=claude_monitor
# HA_DISCOVERY_PREFIX=homeassistant
